# WriCoRe — Environment Variables (Example)
# Copy this file to .env for local dev; NEVER commit .env to Git.
# In production, these are set as encrypted Cloudflare Worker secrets, not env vars.

# Google Gemini API key — get one from https://aistudio.google.com
GEMINI_API_KEY=your-gemini-key-here

# Groq API key — get one from https://console.groq.com
GROQ_API_KEY=your-groq-key-here

# Optional: Override the default Cloudflare Worker URL used by the frontend during local dev
# WORKER_URL=http://localhost:8787/
